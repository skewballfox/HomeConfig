#!/bin/bash

# Target current directory by default, or accept a path as an argument
TARGET_DIR="${1:-.}"

if [ ! -d "$TARGET_DIR/.git" ] && ! git -C "$TARGET_DIR" rev-parse --is-inside-work-tree &>/dev/null; then
    echo "❌ Error: '$TARGET_DIR' is not a git repository."
    exit 1
fi

cd "$TARGET_DIR" || exit 1

CURRENT_URL=$(git remote get-url origin 2>/dev/null)

if [ -z "$CURRENT_URL" ]; then
    echo "❌ Error: No 'origin' remote found."
    exit 1
fi

# Regex matches both github.com and gitlab.com domains
if [[ "$CURRENT_URL" =~ ^https://(github|gitlab)\.com/([^/]+)/(.+)$ ]]; then
    DOMAIN="${BASH_REMATCH[1]}"
    USER="${BASH_REMATCH[2]}"
    REPO="${BASH_REMATCH[3]}"
    
    # Strip a trailing .git if the regex accidentally hoarded it
    REPO="${REPO%.git}.git"

    SSH_URL="git@${DOMAIN}.com:${USER}/${REPO}"
    
    git remote set-url origin "$SSH_URL"
    echo "✅ Switched origin to SSH: $SSH_URL"
else
    echo "ℹ️ Origin is already SSH or isn't a recognized HTTPS URL ($CURRENT_URL)."
fi
